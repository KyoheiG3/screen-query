{
  "name": "screen-query",
  "version": "0.0.1",
  "description": "React Query integration for synchronous multi-query management with Suspense/ErrorBoundary",
  "author": "KyoheiG3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyoheiG3/screen-query.git"
  },
  "homepage": "https://github.com/KyoheiG3/screen-query",
  "bugs": {
    "url": "https://github.com/KyoheiG3/screen-query/issues"
  },
  "keywords": [
    "react",
    "react-query",
    "tanstack-query",
    "suspense",
    "error-boundary",
    "query",
    "state-management",
    "typescript"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tanstack/react-query": "^5.89.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
